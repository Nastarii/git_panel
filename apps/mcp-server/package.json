{
  "name": "@gitpanel/mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "GitPanel MCP server — exposes board data to Claude CLI",
  "type": "module",
  "bin": {
    "gitpanel-mcp": "./dist/index.js"
  },
  "scripts": {
    "dev": "node --import tsx/esm src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@octokit/rest": "^20.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "rimraf": "^5.0.5",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0"
  }
}
