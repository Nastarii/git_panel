# ---------------------------------------------------------------------------
# GitPanel — Desktop environment variables (development only)
#
# Copy this file to `.env` and fill in the values you want to use.
# ---------------------------------------------------------------------------

# EITHER: Personal Access Token (easiest for devs)
#   Generate at: https://github.com/settings/tokens
#   Scopes needed: repo, read:user, read:org
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# OR: OAuth Device Flow (the same path shipped to end-user builds)
#   Create a GitHub OAuth App at https://github.com/settings/developers
#   and check "Enable Device Flow" under "Device Flow".
#   No client secret is required for device flow.
# GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx

# Optional — Cloud mode (Phase 3)
# GITPANEL_API_URL=http://localhost:3333
